{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Linux / macOS)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_COMPILE_WARNING_AS_ERROR": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Linux / macOS)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-msvc",
      "displayName": "Debug (Windows MSVC)",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_COMPILE_WARNING_AS_ERROR": "ON"
      }
    },
    {
      "name": "release-msvc",
      "displayName": "Release (Windows MSVC)",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage (Linux / macOS)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_COMPILE_WARNING_AS_ERROR": "OFF",
        "CMAKE_CXX_FLAGS": "--coverage",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage",
        "CMAKE_SHARED_LINKER_FLAGS": "--coverage"
      }
    },
    {
      "name": "asan",
      "displayName": "AddressSanitizer (Linux / macOS)",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": "OFF",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    }
  ],

  "buildPresets": [
    { "name": "debug",        "configurePreset": "debug"        },
    { "name": "release",      "configurePreset": "release"      },
    { "name": "debug-msvc",   "configurePreset": "debug-msvc",   "configuration": "Debug"   },
    { "name": "release-msvc", "configurePreset": "release-msvc", "configuration": "Release" },
    { "name": "coverage",     "configurePreset": "coverage"     },
    { "name": "asan",         "configurePreset": "asan"         }
  ],

  "testPresets": [
    { "name": "debug",        "configurePreset": "debug",        "output": { "outputOnFailure": true }, "execution": { "noTestsAction": "error" } },
    { "name": "release",      "configurePreset": "release",      "output": { "outputOnFailure": true }, "execution": { "noTestsAction": "error" } },
    { "name": "debug-msvc",   "configurePreset": "debug-msvc",   "configuration": "Debug",   "output": { "outputOnFailure": true }, "execution": { "noTestsAction": "error" } },
    { "name": "release-msvc", "configurePreset": "release-msvc", "configuration": "Release", "output": { "outputOnFailure": true }, "execution": { "noTestsAction": "error" } },
    { "name": "coverage",     "configurePreset": "coverage",     "output": { "outputOnFailure": true }, "execution": { "noTestsAction": "error" } },
    { "name": "asan",         "configurePreset": "asan",         "output": { "outputOnFailure": true }, "execution": { "noTestsAction": "error" } }
  ]
}
